# ─────────────────────────────────────────────────────────────
# Smart Edu Frontend — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# ⚠️  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Backend API proxy target (Vite dev server only)
# In production, configure your reverse-proxy (nginx/Caddy) instead.
VITE_API_TARGET=http://localhost:8080

# WebSocket endpoint override (optional)
# Leave empty to auto-detect from window.location (recommended for production)
# Example: VITE_WS_URL=wss://api.smartedu.example.com/ws-board
VITE_WS_URL=
